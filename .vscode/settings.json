{
    "cSpell.words": [
        "dcloudio",
        "jzczu",
        "kuaishou",
        "quickapp",
        "stacktracey",
        "toutiao",
        "weixin"
    ],
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "[vue]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "[typescript]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "[javascript]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "[json]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "[html]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "[css]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "[scss]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "[less]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit",
        "source.organizeImports": "explicit"
    }
}
